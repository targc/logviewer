# Quickwit Configuration
QUICKWIT_URL=http://your-quickwit-host:17280
QUICKWIT_INDEX=k8s-logs-prod

# Quickwit Basic Auth (optional - leave empty if no auth required)
QUICKWIT_USER=
QUICKWIT_PASS=

# Web Application Basic Auth (REQUIRED - defaults to admin/admin123 if not set)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=admin123
